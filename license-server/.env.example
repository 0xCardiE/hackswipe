# Server
PORT=3847
NODE_ENV=production

# SQLite database file (created automatically)
DATABASE_PATH=./data/licenses.db

# Required for POST /admin/* routes
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Optional comma-separated list of allowed browser extension origins
# Production: add your Chrome extension origin after Web Store publish, e.g.:
# ALLOWED_ORIGINS=chrome-extension://abcdefghijklmnop
ALLOWED_ORIGINS=
