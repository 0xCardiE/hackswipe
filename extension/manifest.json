{
  "manifest_version": 3,
  "name": "HackSwipe",
  "version": "1.0.0",
  "description": "Free, open-source Tinder auto-swiper with smart filters. Set age, distance, photos, and bio keywords — then let it swipe while you live your life.",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://tinder.com/*",
    "https://*.tinder.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tinder.com/*",
        "https://*.tinder.com/*"
      ],
      "js": ["lib/storage.js", "content/tinder.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "ui/index.html"
  },
  "action": {
    "default_title": "HackSwipe",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
