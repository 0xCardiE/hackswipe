{
  "manifest_version": 3,
  "name": "HackSwipe",
  "version": "1.0.0",
  "description": "Auto-swipe on Tinder with smart filters — age, distance, photos, and keywords. 3-day free trial, then a one-time $20 lifetime unlock.",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://tinder.com/*",
    "https://*.tinder.com/*",
    "http://127.0.0.1:3847/*",
    "http://localhost:3847/*",
    "https://license.hackswipe.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tinder.com/*",
        "https://*.tinder.com/*"
      ],
      "js": ["config.js", "lib/storage.js", "lib/license.js", "content/tinder.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "ui/index.html"
  },
  "action": {
    "default_title": "HackSwipe",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
