# E2E test environment — copy to .env and fill Stripe test keys for checkout tests.
# Webhook tests use E2E_WEBHOOK_SECRET (no Stripe API needed).

# Fixed secret for signing webhook fixtures in tests (must match landing STRIPE_WEBHOOK_SECRET when servers start)
E2E_WEBHOOK_SECRET=whsec_e2e_test_signing_secret_32chars

# Shared admin key between license-server and landing during tests
E2E_ADMIN_KEY=e2e-test-admin-key-not-for-production

# Checkout E2E — copy from landing/.env or Stripe Dashboard (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Default E2E ports (avoid clashing with dev servers on 3000 / 3847)
# E2E_LANDING_PORT=3001
# E2E_LICENSE_SERVER_PORT=13847
