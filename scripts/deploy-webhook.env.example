# Copy to deploy-webhook.env (gitignored) and set your GitHub webhook secret.
# GitHub → repo → Settings → Webhooks → your push hook → Secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Optional overrides
# DEPLOY_BRANCH=master
# DEPLOY_WEBHOOK_HOST=127.0.0.1
# DEPLOY_WEBHOOK_PORT=19081
