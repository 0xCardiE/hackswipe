# =============================================================================
# HackSwipe — Landing / Checkout
# =============================================================================
# Copy to .env and fill in values.
# Local dev: keep localhost URLs below.
# Production: use the commented block at the bottom on your server.

# Public site URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Displayed on pricing page (actual charge comes from Stripe Price)
NEXT_PUBLIC_PRODUCT_NAME=HackSwipe Lifetime
# Amounts only (no $) — display formatting happens in src/lib/pricing.ts
NEXT_PUBLIC_PRODUCT_PRICE=20
NEXT_PUBLIC_PRODUCT_ORIGINAL_PRICE=49
NEXT_PUBLIC_FREE_TRIAL_DAYS=3

# -----------------------------------------------------------------------------
# STRIPE (required for checkout)
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/test/products
# Checkout uses STRIPE_PRICE_ID (price_...), not STRIPE_PRODUCT_ID (prod_...)

# Optional — not used by hosted Checkout redirect; keep for reference / future Elements
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRODUCT_ID=prod_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook endpoint: POST https://hackswipe.app/api/webhooks/stripe
# Events: checkout.session.completed

# -----------------------------------------------------------------------------
# LICENSE SERVER (required for auto license delivery)
# -----------------------------------------------------------------------------
LICENSE_SERVER_URL=http://127.0.0.1:3847
LICENSE_SERVER_ADMIN_KEY=same-as-license-server-ADMIN_API_KEY

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
# Use "log" in development (prints license email to terminal)
# Use "resend" in production (or testing real delivery)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
# Production: verify xlcommerce.hr in Resend (shared sender for all products)
EMAIL_FROM=licenses@xlcommerce.hr
EMAIL_FROM_NAME=HackSwipe

# -----------------------------------------------------------------------------
# Production server (.env on host — not for local dev)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://hackswipe.app
# LICENSE_SERVER_URL=https://license.hackswipe.app
# EMAIL_PROVIDER=resend
# EMAIL_FROM=licenses@xlcommerce.hr
# Stripe live webhook: https://hackswipe.app/api/webhooks/stripe
